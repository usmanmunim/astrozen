---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import type { AboutProps, HeroProps } from "@types";

type Props = AboutProps & Pick<HeroProps, "name">;

const { description, image, name } = Astro.props;

const paragraphs = description
  .trim()
  .split(/\n\n+/)
  .map((p) => p.trim())
  .filter(Boolean);
---

<Section text="About Me" href="about">
  <div class="flex flex-col-reverse items-center gap-8 reveal md:flex-row md:items-center md:gap-12">
    <div class="flex-1 space-y-4 w-full">
      {paragraphs.map((para) => <p class="text-sm leading-relaxed text-neutral/80 md:text-base">{para}</p>)}
    </div>

    <div class="shrink-0">
      <div class="overflow-hidden rounded-xl border border-white/10">
        <Image
          class="block h-40 w-36 object-cover object-center md:h-72 md:w-60"
          src={image}
          width="240"
          height="288"
          alt={name}
        />
      </div>
    </div>
  </div>
</Section>
