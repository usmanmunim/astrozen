---
interface Props {
  text: string;
  href: string;
}

const { text, href } = Astro.props;
---

<section id={href} class="py-14 md:py-20">
  <div class="reveal mb-8 md:mb-10">
    <h2 class="font-serif text-2xl font-bold text-white md:text-4xl">{text}</h2>
    <div class="accent-line mt-3 h-px w-10 bg-primary/50"></div>
  </div>
  <slot />
</section>
