---
import Section from "./Section.astro";
import type { ExperienceProps } from "@types";

interface Props {
  experience: ExperienceProps[];
}

const { experience } = Astro.props;
---

<Section text="Experience" href="experience">
  {
    experience.map(({ company, position, startDate, endDate, summary }, i) => (
      <div class="reveal-left mb-8 last:mb-0" style={`transition-delay: ${i * 80}ms`}>
        <div class="flex flex-wrap items-baseline justify-between gap-2 mb-1">
          <h3 class="text-base font-semibold text-white">{position}</h3>
          <span class="text-xs tabular-nums text-neutral/40 shrink-0">{startDate} – {endDate}</span>
        </div>
        <p class="text-sm font-medium text-primary/70 mb-3">{company}</p>

        {Array.isArray(summary) ? (
          <ul class="space-y-2">
            {summary.map((log) => (
              <li class="flex gap-3 text-sm leading-relaxed text-neutral/80">
                <span class="mt-[7px] w-1 h-1 rounded-full bg-primary/40 shrink-0"></span>
                {log}
              </li>
            ))}
          </ul>
        ) : (
          <p class="text-sm leading-relaxed text-neutral/80">{summary}</p>
        )}
      </div>
    ))
  }
</Section>
