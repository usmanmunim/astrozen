---
import type { SiteConfig } from "@types";

type Props = Pick<SiteConfig, "author" | "socialLinks">;

const { author, socialLinks } = Astro.props;
---

<footer class="mt-16 border-t border-white/[0.06] py-8">
  <div class="px-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">

    <p class="footer-author">{author}</p>

    <ul class="flex flex-row gap-2">
      {
        socialLinks.map(({ text, href }, i) => (
          <li>
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class={`footer-btn ${i === 0 ? "footer-btn-primary" : "footer-btn-outline"}`}
            >
              {text}
            </a>
          </li>
        ))
      }
    </ul>

  </div>
</footer>

<style>
  .footer-author {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--heading);
  }
.footer-btn {
    display: inline-flex;
    align-items: center;
    padding: 5px 10px;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }
  @media (min-width: 640px) {
    .footer-btn { padding: 6px 14px; font-size: 0.8125rem; }
  }

  .footer-btn-primary {
    background-color: #2563eb;
    color: #fff;
    border: 1px solid transparent;
  }
  .footer-btn-primary:hover { background-color: #1d4ed8; }

  .footer-btn-outline {
    background-color: transparent;
    color: var(--body);
    border: 1px solid var(--border);
  }
  .footer-btn-outline:hover {
    border-color: var(--border-md);
    color: var(--heading);
  }
</style>
