---
import Section from "./Section.astro";
import { SITE_CONTENT } from "@config";
import {
  siPython, siFlutter, siFirebase, siC, siCplusplus,
  siLinux, siUbuntu, siCisco, siRockylinux,
  siDotnet, siSharp, siJavascript, siHtml5, siCss, siGithub,
  siDart, siGit, siAndroidstudio, siVirtualbox, siSap, siApachenetbeanside
} from "simple-icons";

const { skills } = SITE_CONTENT;

interface IconDef {
  svgInner: string;
  hex: string;
}

function brandIcon(icon: { path: string; hex: string }): IconDef {
  return { svgInner: `<path fill="currentColor" d="${icon.path}"/>`, hex: icon.hex };
}

function lineIcon(paths: string, hex: string): IconDef {
  return {
    svgInner: `<g fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${paths}</g>`,
    hex,
  };
}

const skillIcons: Record<string, IconDef> = {
