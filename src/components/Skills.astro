    "22c55e"
  ),
};

// Pre-compute rgba values at build time — no CSS color-mix needed
function rgba(hex: string, alpha: number): string {
  const r = parseInt(hex.slice(0, 2), 16);
  const g = parseInt(hex.slice(2, 4), 16);
  const b = parseInt(hex.slice(4, 6), 16);
  return `rgba(${r},${g},${b},${alpha})`;
}
---

<Section text="Skills" href="skills">
  <div class="space-y-8">
    {skills.map(({ group, items }, i) => (
      <div class="reveal" style={`transition-delay: ${i * 120}ms`}>
        <p class="text-xs font-semibold text-neutral/50 uppercase tracking-widest mb-3">{group}</p>
        <div class="flex flex-wrap gap-2">
          {items.map((item) => {
            const icon = skillIcons[item];
            const hex = icon?.hex ?? "3b82f6";
            return (
              <span
                class="skill-tag"
                style={`--brand: #${hex}; --brand-glow: ${rgba(hex, 0.28)};`}
              >
                {icon && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    width="14"
                    height="14"
                    style={`color: #${hex}`}
                    aria-hidden="true"
                    set:html={icon.svgInner}
                  />
                )}
                {item}
              </span>
            );
          })}
        </div>
      </div>
    ))}
  </div>
</Section>

<style>
  .skill-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 18px;
    border-radius: 9px;
    white-space: nowrap;
    font-size: 14.5px;
    font-weight: 500;
    cursor: default;
    color: var(--body);
    background: var(--tag-bg);
    border: 1px solid var(--tag-border);
    transition: color 0.2s ease, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                background 0.2s ease, border-color 0.2s ease;
    will-change: transform;
  }
  .skill-tag:hover {
    color: var(--tag-hover-color);
    border-color: var(--tag-hover-border);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px var(--brand-glow);
  }

  /* Icon: color is set via inline style — only animate transform here */
  svg {
    flex-shrink: 0;
    display: block;
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .skill-tag:hover svg {
    transform: scale(1.2) rotate(6deg);
  }
</style>
